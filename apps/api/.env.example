# ============================================================
# GOLDEN TOWER ERP — Variables de Entorno del Backend (API)
# ============================================================
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el .env real al repositorio.
# ============================================================

# URL del Frontend (para CORS)
FRONTEND_URL=http://localhost:3000

# --- Firebase Admin SDK ---
# Obtén estos valores de: Firebase Console → Configuración del Proyecto → Cuentas de Servicio
ADMIN_PROJECT_ID=tu-project-id
ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-project-id.iam.gserviceaccount.com
ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTU_LLAVE_PRIVADA_AQUI\n-----END PRIVATE KEY-----\n"

# --- Correo SMTP (para notificaciones) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-app-password-de-gmail

# --- Sentry (Error Tracking & Monitoring) ---
# Obtén tu DSN desde: https://sentry.io → Settings → Projects → [Your Project] → Client Keys (DSN)
# Deja vacío para deshabilitar Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Swagger/OpenAPI ---
# En producción, Swagger se deshabilita por defecto.
# Establece a "true" para habilitarlo en producción (solo para debugging)
ENABLE_SWAGGER=false

# ============================================================
# PRODUCCIÓN (Firebase Cloud Functions):
# Las variables se configuran en el archivo apps/api/.env
# que Firebase CLI sube automáticamente al hacer deploy.
# NO se usan variables de entorno del sistema en Cloud Functions.
# ============================================================
